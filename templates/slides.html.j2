<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <style>
        {% include 'viewport-base.css.j2' %}

        :root {
            --hw-red: #CF0A2C;            /* Pantone 185C, cross-verified */
            --hw-red-rgb: 207, 10, 44;
            --hw-red-soft: rgba(var(--hw-red-rgb), 0.08);
            --hw-red-medium: rgba(var(--hw-red-rgb), 0.18);
            --hw-title: #231815;
            --hw-body: #595757;
            --hw-med-gray: #999999;
            --hw-white: #FFFFFF;
            --hw-light-gray: #DCDDDD;
            --hw-bg-gray: #F5F5F5;
            --hw-orange: #FF9900;
            --hw-yellow: #FCC800;
            --hw-green: #669900;
            --hw-blue: #007DFF;           /* tech blue (Huawei Cloud primary) */
            --hw-ictblue: #30B5C5;        /* ICT Academy accent blue */
            --font-zh: "Microsoft YaHei", "PingFang SC", "Hiragino Sans GB", sans-serif;
            --font-en: Arial, "Helvetica Neue", sans-serif;

            /* Frontend-slides inspired motion */
            --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
            --duration-normal: 0.7s;
        }

        body {
            font-family: var(--font-zh);
            background: var(--hw-light-gray);
        }

        /* Override deck-stage host background for Huawei light theme */
        deck-stage {
            --stage-bg: var(--hw-light-gray);
            --slide-bg: var(--hw-white);
        }

        .slide {
            background: var(--hw-white);
            color: var(--hw-body);
            font-family: var(--font-zh);
        }

        .slide h1, .slide h2, .slide h3 {
            color: var(--hw-title);
            font-weight: bold;
            margin: 0;
        }

        .accent-red { color: var(--hw-red); }
        .accent-bg-red { background-color: var(--hw-red); }
        .accent-bg-blue { background-color: var(--hw-blue); }
        .accent-bg-yellow { background-color: var(--hw-yellow); }
        .accent-bg-orange { background-color: var(--hw-orange); }
        .accent-bg-green { background-color: var(--hw-green); }
        .accent-bg-ictblue { background-color: var(--hw-ictblue); }
        .accent-bg-gray { background-color: var(--hw-light-gray); }

        .slide-content {
            position: absolute;
            inset: 0;
            width: 1920px;
            height: 1080px;
            box-sizing: border-box;
        }

        /* Slide chrome: page number, source */
        .slide-number {
            position: absolute;
            top: 56px;
            left: 80px;
            font-family: var(--font-en);
            font-size: 18px;
            font-weight: 700;
            letter-spacing: 0.15em;
            color: var(--hw-red);
        }

        .slide-source {
            position: absolute;
            bottom: 56px;
            right: 80px;
            font-size: 18px;
            color: var(--hw-body);
            font-family: var(--font-en);
            letter-spacing: 0.02em;
        }

        .top-accent-bar {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 8px;
            background: linear-gradient(90deg, var(--hw-red) 0%, #E85D3E 60%, var(--hw-orange) 100%);
        }

        .section-title {
            font-size: 64px;
            line-height: 1.15;
            margin-bottom: 48px;
            max-width: 1600px;
        }

        /* Card system */
        .card {
            background: var(--hw-white);
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(35, 24, 21, 0.08);
            border: 1px solid var(--hw-light-gray);
            overflow: hidden;
        }

        .card-top-red { border-top: 6px solid var(--hw-red); }
        .card-top-blue { border-top: 6px solid var(--hw-blue); }
        .card-top-ictblue { border-top: 6px solid var(--hw-ictblue); }
        .card-top-yellow { border-top: 6px solid var(--hw-yellow); }
        .card-top-orange { border-top: 6px solid var(--hw-orange); }
        .card-top-green { border-top: 6px solid var(--hw-green); }
        .card-top-gray { border-top: 6px solid var(--hw-light-gray); }

        /* Metric cards */
        .metric-card {
            background: var(--hw-white);
            border-radius: 16px;
            padding: 44px;
            box-shadow: 0 12px 40px rgba(35, 24, 21, 0.08);
            border: 1px solid var(--hw-light-gray);
            border-top: 6px solid var(--hw-red);
        }

        .metric-value {
            font-family: var(--font-zh);
            font-size: 72px;
            font-weight: 800;
            color: var(--hw-red);
            line-height: 1;
            margin-bottom: 16px;
        }

        .metric-label {
            font-size: 30px;
            font-weight: 700;
            color: var(--hw-title);
            margin-bottom: 12px;
        }

        .metric-desc {
            font-size: 22px;
            color: var(--hw-body);
            line-height: 1.5;
        }

        /* Modern data table */
        .data-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            font-size: 26px;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(35, 24, 21, 0.06);
        }

        .data-table thead th {
            background: var(--hw-title);
            color: var(--hw-white);
            padding: 26px 32px;
            text-align: left;
            font-weight: 700;
            border-bottom: 3px solid var(--hw-red);
        }

        .data-table tbody td {
            padding: 24px 32px;
            border-bottom: 1px solid var(--hw-light-gray);
            color: var(--hw-body);
            background: var(--hw-white);
        }

        .data-table tbody tr:last-child td {
            border-bottom: none;
        }

        .data-table tbody tr:hover td {
            background: var(--hw-bg-gray);
        }

        .data-table tbody td strong {
            color: var(--hw-title);
            font-weight: 700;
        }

        /* Tag / pill */
        .tag {
            display: inline-block;
            font-size: 16px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            padding: 6px 14px;
            border-radius: 6px;
            font-weight: 700;
        }

        .tag-red { color: var(--hw-red); background: var(--hw-red-soft); }
        .tag-gold { color: var(--hw-orange); background: rgba(255, 153, 0, 0.10); }
        .tag-blue { color: var(--hw-blue); background: rgba(0, 125, 255, 0.10); }
        .tag-green { color: var(--hw-green); background: rgba(102, 153, 0, 0.10); }

        /* Risk / action cards */
        .risk-card {
            background: var(--hw-white);
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 10px 36px rgba(35, 24, 21, 0.08);
            border: 1px solid var(--hw-light-gray);
            display: flex;
            flex-direction: column;
        }

        .risk-card h3 {
            font-size: 32px;
            margin-bottom: 16px;
            line-height: 1.3;
        }

        .risk-card p {
            font-size: 22px;
            color: var(--hw-body);
            line-height: 1.6;
            margin-bottom: 24px;
        }

        .risk-meta {
            margin-top: auto;
            font-size: 18px;
            color: var(--hw-body);
            border-top: 1px solid var(--hw-light-gray);
            padding-top: 18px;
        }

        /* Headline block */
        .headline-block {
            font-size: 34px;
            color: var(--hw-title);
            line-height: 1.5;
            padding-left: 24px;
            border-left: 6px solid var(--hw-red);
            margin-bottom: 56px;
            max-width: 1500px;
        }

        /* Animation */
        .slide[data-deck-active] .fade-up {
            opacity: 1;
            transform: translateY(0);
        }

        .fade-up {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity var(--duration-normal) var(--ease-out-expo),
                        transform var(--duration-normal) var(--ease-out-expo);
        }

        .fade-up:nth-child(1) { transition-delay: 0.06s; }
        .fade-up:nth-child(2) { transition-delay: 0.12s; }
        .fade-up:nth-child(3) { transition-delay: 0.18s; }
        .fade-up:nth-child(4) { transition-delay: 0.24s; }
        .fade-up:nth-child(5) { transition-delay: 0.30s; }
        .fade-up:nth-child(6) { transition-delay: 0.36s; }
        .fade-up:nth-child(7) { transition-delay: 0.42s; }
        .fade-up:nth-child(8) { transition-delay: 0.48s; }

        {# Huawei official visual framework: left nav rail + arc-red title #}
        {% include 'huawei-frame.css.j2' %}
    </style>
</head>
<body>
    <deck-stage width="1920" height="1080">
        {% for slide in slides %}
        {% set is_frame = slide.slide_type not in ('cover', 'closing') %}
        <section class="slide{% if not is_frame %} no-nav{% endif %}" data-label="{{ slide.idx }} {{ slide.slide_type }}" data-slide-type="{{ slide.slide_type }}">
            {% if is_frame %}
            {# 左侧导航条（华为标志元素）：当前章节高亮 #}
            <nav class="hw-nav fade-up">
                <div class="hw-nav-logo">{{ content.brand | default('华为 ICT') }}</div>
                <div class="hw-nav-section">{{ content.brand_en | default('HUAWEI ICT') }}</div>
                <div class="hw-nav-items">
                    {% for ch in content.chapters | default([]) %}
                    <div class="hw-nav-item{% if ch == slide.chapter | default(content.chapters[0] if content.chapters else '') %} active{% endif %}">{{ ch }}</div>
                    {% endfor %}
                </div>
            </nav>
            {% endif %}
            {% include 'slide-types/' + slide.slide_type + '.html.j2' %}
            {% if is_frame %}
            {% if slide.source %}<div class="hw-source">来源：{{ slide.source }}</div>{% endif %}
            <div class="hw-pageno">{{ slide.number | default(slide.idx) }} / {{ slide.total | default(slides | length) }}</div>
            {% endif %}
        </section>
        {% endfor %}
    </deck-stage>
    <script>
        {% include 'deck-stage.js.j2' %}
    </script>
</body>
</html>
