{% from 'huawei-macros.j2' import hw_title %}
<div class="slide-content" style="padding-top:90px;padding-right:90px;padding-bottom:80px;display:flex;flex-direction:column;height:100%;">
    {{ hw_title(slide) }}
    <div style="display:flex;gap:28px;margin-top:30px;">
        {% for st in slide.stats %}
        <div class="hw-card fade-up" style="flex:1;align-items:center;text-align:center;{% if st.highlight %}background:var(--hw-red);border-top-color:var(--hw-red);{% endif %}">
            <div class="hw-kpi-num" style="{% if st.highlight %}color:#fff;{% else %}color:var(--hw-title);{% endif %}font-family:var(--font-en);">{{ st.value }}</div>
            <div class="hw-kpi-label" style="{% if st.highlight %}color:#fff;{% else %}color:var(--hw-body);{% endif %}">{{ st.label }}</div>
        </div>
        {% endfor %}
    </div>
    {% if slide.detail_items %}
    <div class="fade-up" style="margin-top:auto;padding:22px 30px;background:var(--hw-bg-gray);border-left:5px solid var(--hw-red);font-size:20px;color:var(--hw-body);line-height:1.6;">
        {% for d in slide.detail_items %}{{ d }}{% endfor %}
    </div>
    {% endif %}
</div>
