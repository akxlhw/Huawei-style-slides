<div class="slide-content" style="padding-top:90px;padding-right:90px;padding-bottom:80px;display:flex;flex-direction:column;background:linear-gradient(180deg, #FFFFFF 0%, var(--hw-bg-gray) 100%);">
    {% from 'huawei-macros.j2' import hw_title %}
    {{ hw_title(slide) }}<div class="fade-up" style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:40px;flex:1;align-content:start;">
        {% for it in slide.grid_items %}
        <div style="background:var(--hw-white);border:1px solid var(--hw-light-gray);border-top:6px solid var(--hw-{{ it.color }});border-radius:6px;padding:28px;display:flex;flex-direction:column;">
            <div style="display:flex;align-items:center;gap:18px;margin-bottom:16px;">
                <div style="width:56px;height:56px;border-radius:50%;background:var(--hw-{{ it.color }});color:var(--hw-white);display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:bold;flex-shrink:0;">{{ it.title[0] }}</div>
                <div style="font-size:26px;font-weight:bold;color:var(--hw-{{ it.color }});">{{ it.title }}</div>
            </div>
            <div style="font-size:19px;color:var(--hw-body);line-height:1.6;">{{ it.description }}</div>
        </div>
        {% endfor %}
    </div>
    {% if slide.source %}<div class="slide-source fade-up">来源：{{ slide.source }}</div>{% endif %}
</div>
