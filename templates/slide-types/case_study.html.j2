<div class="slide-content" style="padding-top:90px;padding-right:90px;padding-bottom:80px;display:flex;flex-direction:column;background:linear-gradient(180deg, #FFFFFF 0%, var(--hw-bg-gray) 100%);">
    {% from 'huawei-macros.j2' import hw_title %}
    {{ hw_title(slide) }}<div class="fade-up" style="display:flex;flex-direction:column;gap:20px;margin-top:40px;flex:1;">
        {% for sec in slide.sections %}
        {% set is_last = loop.last %}
        <div style="display:flex;align-items:stretch;background:{% if is_last %}var(--hw-red){% else %}var(--hw-white){% endif %};border:1px solid var(--hw-light-gray);border-radius:8px;overflow:hidden;">
            <div style="width:88px;background:{% if is_last %}rgba(255,255,255,0.18){% else %}var(--hw-bg-gray){% endif %};display:flex;align-items:center;justify-content:center;font-size:48px;font-weight:bold;color:{% if is_last %}var(--hw-white){% else %}var(--hw-red){% endif %};font-family:var(--font-en);">{{ sec.letter }}</div>
            <div style="flex:1;padding:24px 32px;">
                <div style="font-size:24px;font-weight:bold;color:{% if is_last %}var(--hw-white){% else %}var(--hw-title){% endif %};margin-bottom:8px;">{{ sec.title }}</div>
                <div style="font-size:20px;color:{% if is_last %}rgba(255,255,255,0.92){% else %}var(--hw-body){% endif %};line-height:1.5;">{{ sec.description }}</div>
            </div>
        </div>
        {% endfor %}
    </div>

    {% if slide.result_box %}
    <div class="fade-up" style="margin-top:24px;padding:22px 32px;background:var(--hw-title);border-radius:6px;display:flex;align-items:center;gap:24px;">
        <div style="font-size:20px;font-weight:bold;color:var(--hw-red);white-space:nowrap;">{{ slide.result_box[0] }}</div>
        <div style="font-size:22px;color:var(--hw-white);">{{ slide.result_box[1] }}</div>
    </div>
    {% endif %}
    {% if slide.source %}<div class="slide-source fade-up">来源：{{ slide.source }}</div>{% endif %}
</div>
