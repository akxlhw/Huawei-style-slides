<div class="slide-content" style="display:flex; flex-direction:column; justify-content:center; align-items:flex-start; padding:120px 140px;">
    <div class="top-accent-bar"></div>
    <h1 class="fade-up" style="font-size:112px; line-height:1.15; margin-bottom:48px; max-width:1600px;">{{ slide.title }}</h1>
    <p class="fade-up" style="font-size:44px; color:var(--hw-body); margin-bottom:80px;">{{ slide.subtitle }}</p>
    <div class="fade-up" style="margin-top:auto; font-size:28px; color:var(--hw-body);">
        <span>{{ slide.author }}</span> · <span>{{ slide.date }}</span>
    </div>
    <div class="accent-bg-red fade-up" style="position:absolute; top:80px; right:80px; width:16px; height:160px; border-radius:2px;"></div>
</div>
