{% from 'huawei-macros.j2' import hw_title %}
<div class="slide-content" style="padding-top:90px;padding-right:90px;padding-bottom:80px;display:flex;flex-direction:column;height:100%;">
    {{ hw_title(slide) }}
    <div class="fade-up" style="margin-top:20px;flex:1;display:flex;flex-direction:column;">
        {# Phase headers #}
        <div style="display:flex;margin-left:200px;">
            {% for ph in slide.phases %}
            <div style="flex:1;text-align:center;font-size:17px;color:var(--hw-red);font-weight:bold;padding-bottom:10px;">{{ ph }}</div>
            {% endfor %}
        </div>
        {# Lanes #}
        {% set lane_bgs = ['#FCE8EA','#E6F0FF','#EEF6E0','#FFF3E0'] %}
        {% for lane_idx in range(slide.lanes | length) %}
        <div style="display:flex;align-items:stretch;min-height:90px;border-bottom:1px solid var(--hw-line);">
            <div style="flex:0 0 200px;padding:16px 20px;font-size:16px;color:var(--hw-title);font-weight:bold;display:flex;align-items:center;background:var(--hw-bg-gray);">{{ slide.lanes[lane_idx] }}</div>
            <div style="flex:1;display:flex;background:{{ lane_bgs[lane_idx % 4] }};">
                {% for ph_idx in range(slide.phases | length) %}
                <div style="flex:1;padding:10px;border-left:1px dashed var(--hw-line);display:flex;align-items:center;justify-content:center;">
                    {% for step in slide.steps %}
                    {% if step[0] == lane_idx and step[1] == ph_idx %}
                    <div style="background:#fff;border-top:3px solid var(--hw-red);border-radius:6px;padding:10px 12px;font-size:14px;color:var(--hw-title);text-align:center;min-width:80%;">{{ step[2] }}</div>
                    {% endif %}
                    {% endfor %}
                </div>
                {% endfor %}
            </div>
        </div>
        {% endfor %}
    </div>
</div>
