{% from 'huawei-macros.j2' import hw_title %}
<div class="slide-content" style="padding-top:90px;padding-right:90px;padding-bottom:80px;display:flex;flex-direction:column;height:100%;">
    {{ hw_title(slide) }}
    <div class="fade-up" style="margin-top:24px;border:1px solid var(--hw-line);border-radius:10px;overflow:hidden;background:#fff;flex:1;display:flex;flex-direction:column;">
        <div style="display:flex;background:var(--hw-title);">
            {% for col in slide.headers %}
            <div style="flex:1;padding:20px 22px;font-size:17px;color:#fff;font-weight:bold;">{{ col }}</div>
            {% endfor %}
        </div>
        {% for row in slide.rows %}
        <div style="display:flex;{% if not loop.first %}border-top:1px solid var(--hw-line);{% endif %}background:{% if loop.index is even %}var(--hw-bg-gray){% else %}#fff{% endif %};flex:1;">
            {% for cell in row %}
            <div style="flex:1;padding:16px 22px;font-size:17px;color:{% if loop.first %}var(--hw-title){% else %}var(--hw-body){% endif %};{% if loop.first %}font-weight:bold;{% endif %}display:flex;align-items:center;">{{ cell }}</div>
            {% endfor %}
        </div>
        {% endfor %}
    </div>
</div>
