<div class="slide-content" style="padding:120px 140px;">
    <div class="top-accent-bar"></div>
    <h2 class="fade-up" style="font-size:64px; margin-bottom:56px;">{{ slide.title }}</h2>
    <table class="fade-up" style="width:100%; border-collapse:collapse; font-size:28px; color:var(--hw-body);">
        <thead>
            <tr style="background:var(--hw-title); color:var(--hw-white);">
                {% for h in slide.headers %}
                <th style="padding:26px 28px; text-align:left; font-weight:bold; border:1px solid var(--hw-light-gray);">{{ h }}</th>
                {% endfor %}
            </tr>
        </thead>
        <tbody>
            {% for row in slide.rows %}
            <tr style="{% if loop.index0 % 2 == 1 %}background:#F7F7F7;{% endif %}">
                {% for cell in row %}
                <td style="padding:22px 28px; border:1px solid var(--hw-light-gray); color:var(--hw-title);">{{ cell }}</td>
                {% endfor %}
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% if slide.source %}
    <div class="slide-source fade-up">来源：{{ slide.source }}</div>
    {% endif %}
</div>
