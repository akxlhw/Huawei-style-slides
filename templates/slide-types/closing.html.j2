<div class="slide-content" style="display:flex; flex-direction:column; justify-content:center; align-items:center; height:100%;">
    <div class="top-accent-bar"></div>
    <h2 class="fade-up" style="font-size:108px; margin-bottom:40px; text-align:center;">{{ slide.title }}</h2>
    <p class="fade-up" style="font-size:44px; color:var(--hw-body); text-align:center; max-width:1400px; line-height:1.4;">{{ slide.message }}</p>
    <div class="accent-bg-red fade-up" style="width:120px; height:8px; margin-top:80px; border-radius:2px;"></div>
</div>
