<div class="slide-content" style="padding:120px 140px;">
    <div class="top-accent-bar"></div>
    <h2 class="fade-up" style="font-size:64px; margin-bottom:48px;">{{ slide.title }}</h2>
    <div class="fade-up" style="display:flex; gap:48px; align-items:flex-start;">
        <!-- Table -->
        <div style="flex:0 0 980px;">
            <table style="width:100%; border-collapse:collapse; font-size:26px; color:var(--hw-body);">
                <thead>
                    <tr style="background:var(--hw-title); color:var(--hw-white);">
                        {% for h in slide.headers %}
                        <th style="padding:22px 24px; text-align:left; font-weight:bold; border:1px solid var(--hw-light-gray);">{{ h }}</th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for row in slide.rows %}
                    <tr style="{% if loop.index0 % 2 == 1 %}background:#F7F7F7;{% endif %}">
                        {% for cell in row %}
                        <td style="padding:18px 24px; border:1px solid var(--hw-light-gray); color:var(--hw-title);">{{ cell }}</td>
                        {% endfor %}
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <!-- Insights -->
        <div style="flex:1; background:#F7F7F7; border-left:6px solid var(--hw-red); padding:32px; border-radius:4px;">
            <div style="font-size:28px; font-weight:bold; color:var(--hw-title); margin-bottom:24px;">启示：</div>
            <div style="display:flex; flex-direction:column; gap:18px;">
                {% for insight in slide.insights %}
                <div style="display:flex; gap:14px; align-items:flex-start;">
                    <div style="width:10px; height:10px; background:var(--hw-red); border-radius:50%; margin-top:10px; flex-shrink:0;"></div>
                    <div style="font-size:24px; color:var(--hw-body); line-height:1.5;">{{ insight }}</div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
    {% if slide.source %}
    <div class="slide-source fade-up">来源：{{ slide.source }}</div>
    {% endif %}
</div>
