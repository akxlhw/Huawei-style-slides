{% from 'huawei-macros.j2' import hw_title %}
<div class="slide-content" style="padding-top:90px;padding-right:90px;padding-bottom:80px;display:flex;flex-direction:column;height:100%;">
    {{ hw_title(slide) }}
    <div class="fade-up" style="display:flex;flex-direction:column;gap:20px;margin-top:30px;">
        {% for b in slide.bars %}
        <div style="display:flex;align-items:center;gap:22px;">
            <div style="width:240px;font-size:20px;color:var(--hw-title);font-weight:bold;text-align:right;">{{ b.label }}</div>
            <div style="flex:1;height:40px;background:var(--hw-light-gray);border-radius:4px;overflow:hidden;">
                <div style="width:{{ b.pct }}%;height:100%;background:var(--hw-{{ b.color }});border-radius:4px;display:flex;align-items:center;justify-content:flex-end;padding-right:14px;color:#fff;font-size:18px;font-weight:bold;">{{ b.raw }}</div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% if slide.summary %}
    <div class="fade-up" style="margin-top:auto;padding:18px 28px;background:var(--hw-bg-gray);border-left:5px solid var(--hw-red);font-size:20px;color:var(--hw-title);">
        <strong>{{ slide.summary[0] }}：</strong>{{ slide.summary[1] }}
    </div>
    {% endif %}
</div>
