<div class="slide-content" style="padding:120px 140px;">
    <div class="top-accent-bar"></div>
    <h2 class="fade-up" style="font-size:64px; margin-bottom:56px;">{{ slide.title }}</h2>
    <p class="fade-up" style="font-size:38px; color:var(--hw-title); margin-bottom:72px; border-left:10px solid var(--hw-red); padding-left:32px; line-height:1.4; max-width:1640px;">
        {{ slide.headline }}
    </p>
    <div style="display:flex; flex-direction:column; gap:36px;">
        {% for item in slide['items'] %}
        <div class="fade-up" style="display:flex; gap:28px; align-items:flex-start;">
            <div style="width:18px; height:18px; background:var(--hw-red); border-radius:50%; margin-top:14px; flex-shrink:0;"></div>
            <div>
                <div style="font-size:32px; color:var(--hw-title); font-weight:bold; margin-bottom:8px;">{{ item.title }}</div>
                <div style="font-size:28px; line-height:1.5;">{{ item.description }}</div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% if slide.source %}
    <div class="slide-source fade-up">来源：{{ slide.source }}</div>
    {% endif %}
</div>
