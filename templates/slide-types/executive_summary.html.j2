{% from 'huawei-macros.j2' import hw_title %}
<div class="slide-content" style="padding-top:90px;padding-right:90px;padding-bottom:80px;display:flex;flex-direction:column;height:100%;">
    {{ hw_title(slide) }}
    <div style="display:flex;gap:28px;flex:1;align-items:stretch;">
        {% for item in slide['items'] %}
        <div class="hw-card fade-up" style="flex:1;align-items:center;text-align:center;border-top-width:5px;">
            <div style="width:64px;height:64px;border-radius:50%;background:var(--hw-red);color:#fff;display:flex;align-items:center;justify-content:center;font-size:30px;font-weight:bold;margin-bottom:22px;">{{ item.title }}</div>
            <div class="hw-card-title">{{ item.subtitle | default(item.title) }}</div>
            <div class="hw-card-desc" style="margin-top:auto;">{{ item.description }}</div>
        </div>
        {% endfor %}
    </div>
</div>
