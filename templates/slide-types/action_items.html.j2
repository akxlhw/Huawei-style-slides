<div class="slide-content" style="padding-top:90px;padding-right:90px;padding-bottom:80px;display:flex;flex-direction:column;background:linear-gradient(180deg, #FFFFFF 0%, var(--hw-bg-gray) 100%);">
    {% from 'huawei-macros.j2' import hw_title %}
    {{ hw_title(slide) }}

    <div style="display:flex;gap:36px;flex:1;align-items:stretch;">
        {% for action in slide.actions %}
        <div class="risk-card fade-up card-top-{{ action.color | default('red') }}" style="flex:1;">
            <div style="margin-bottom:18px;">
                {% if action.impact is defined %}
                <span class="tag tag-red" style="margin-right:10px;">{{ action.impact }}</span>
                {% endif %}
                <span class="tag tag-gold">{{ action.timeline }}</span>
            </div>
            <h3 style="font-size:32px;">{{ action.title }}</h3>
            <p>{{ action.description }}</p>
            <div class="risk-meta">
                负责人：<strong style="color:var(--hw-title);">{{ action.owner }}</strong>
            </div>
        </div>
        {% endfor %}
    </div>

    {% if slide.number is defined %}
    <div class="slide-number">{{ slide.number }}</div>
    {% endif %}
</div>
