<div class="slide-content" style="padding:120px 140px;display:flex;flex-direction:column;justify-content:center;background:linear-gradient(135deg, var(--hw-title) 0%, #3a2a26 100%);">
    <div class="fade-up" style="font-size:120px;color:var(--hw-red);font-family:var(--font-en);line-height:0.6;height:60px;opacity:0.9;">"</div>
    <div class="fade-up" style="font-size:38px;line-height:1.6;color:var(--hw-white);max-width:1400px;font-weight:300;margin-top:24px;">
        {{ slide.quote_text }}
    </div>
    <div class="fade-up" style="display:flex;align-items:center;gap:20px;margin-top:48px;">
        <div style="width:48px;height:3px;background:var(--hw-red);"></div>
        <div style="font-size:22px;color:var(--hw-light-gray);">{{ slide.attribution }}</div>
    </div>
</div>
