<div class="slide-content" style="padding:120px 140px;">
    <div class="top-accent-bar"></div>
    <h2 class="fade-up" style="font-size:64px; margin-bottom:56px;">{{ slide.title }}</h2>
    {% set max_value = namespace(value=1) %}
    {% for stage in slide.stages %}
        {% if stage.value > max_value.value %}{% set max_value.value = stage.value %}{% endif %}
    {% endfor %}
    <div class="fade-up" style="display:flex; flex-direction:column; align-items:center; gap:18px; margin-top:40px;">
        {% for stage in slide.stages %}
        {% set pct = stage.value / max_value.value %}
        {% set bar_w = 900 + (pct * 700) | int %}
        <div style="display:flex; align-items:center; gap:28px; width:100%; justify-content:center;">
            <div style="width:{{ bar_w }}px; height:72px; background:{% if loop.first %}var(--hw-red){% else %}var(--hw-light-gray){% endif %}; display:flex; align-items:center; justify-content:space-between; padding:0 28px; box-sizing:border-box; border-radius:4px;">
                <span style="font-size:26px; font-weight:bold; color:{% if loop.first %}var(--hw-white){% else %}var(--hw-title){% endif %};">{{ stage.label }}</span>
                <span style="font-size:24px; color:{% if loop.first %}var(--hw-white){% else %}var(--hw-body){% endif %};">{{ stage.value }}</span>
            </div>
            {% if not loop.last %}
            <div style="font-size:22px; color:var(--hw-body); width:90px;">→ {{ (stage.value / slide.stages[loop.index0 + 1].value * 100) | int }}%</div>
            {% endif %}
        </div>
        {% endfor %}
    </div>
    {% if slide.source %}
    <div class="slide-source fade-up">来源：{{ slide.source }}</div>
    {% endif %}
</div>
