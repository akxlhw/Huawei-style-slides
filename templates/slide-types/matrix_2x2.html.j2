{% from 'huawei-macros.j2' import hw_title %}
<div class="slide-content" style="padding-top:90px;padding-right:90px;padding-bottom:80px;display:flex;flex-direction:column;height:100%;">
    {{ hw_title(slide) }}
    <div class="fade-up" style="display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;gap:24px;flex:1;margin-top:10px;">
        {% for quadrant in slide.quadrants %}
        <div class="hw-card {{ quadrant.color | default('red') }}" style="border-top-width:5px;">
            <div class="hw-card-title" style="color:var(--hw-{{ quadrant.color | default('red') }});font-size:24px;margin-bottom:16px;">{{ quadrant.label }}</div>
            <div style="display:flex;flex-direction:column;gap:11px;">
                {% for item in quadrant['items'] %}
                <div style="display:flex;gap:11px;align-items:flex-start;font-size:19px;color:var(--hw-body);line-height:1.5;">
                    <div style="width:7px;height:7px;background:var(--hw-{{ quadrant.color | default('red') }});margin-top:10px;flex-shrink:0;border-radius:50%;"></div>
                    <div>{{ item }}</div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endfor %}
    </div>
</div>
