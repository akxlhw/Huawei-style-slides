{% from 'huawei-macros.j2' import hw_title %}
<div class="slide-content" style="padding-top:90px;padding-right:90px;padding-bottom:80px;display:flex;flex-direction:column;height:100%;">
    {{ hw_title(slide) }}
    <div class="fade-up" style="display:flex;gap:32px;margin:20px 0 12px;">
        {% for s in slide.chart.series %}
        <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:18px;height:18px;background:var(--hw-{{ s.color }});"></div>
            <span style="font-size:19px;color:var(--hw-body);">{{ s.name }}</span>
        </div>
        {% endfor %}
    </div>
    <div class="fade-up" style="display:flex;align-items:flex-end;gap:0;flex:1;border-bottom:2px solid var(--hw-title);padding:0 16px;">
        {% for g in slide.chart.groups %}
        <div style="flex:1;display:flex;flex-direction:column;align-items:center;height:100%;justify-content:flex-end;">
            <div style="display:flex;align-items:flex-end;gap:10px;height:100%;">
                {% for b in g.bars %}
                <div style="width:44px;height:calc({{ b.height_pct }}% - 30px);background:var(--hw-{{ b.color }});border-radius:3px 3px 0 0;position:relative;display:flex;justify-content:center;">
                    <span style="position:absolute;top:-24px;font-size:14px;color:var(--hw-body);font-weight:bold;">{{ b.value }}</span>
                </div>
                {% endfor %}
            </div>
            <div style="font-size:17px;color:var(--hw-body);margin-top:12px;">{{ g.category }}</div>
        </div>
        {% endfor %}
    </div>
    {% if slide.summary %}
    <div class="fade-up" style="margin-top:16px;padding:18px 28px;background:var(--hw-bg-gray);border-left:5px solid var(--hw-red);font-size:20px;color:var(--hw-title);">
        <strong>{{ slide.summary[0] }}：</strong>{{ slide.summary[1] }}
    </div>
    {% endif %}
</div>
