{% from 'huawei-macros.j2' import hw_title %}
<div class="slide-content" style="padding-top:90px;padding-right:90px;padding-bottom:80px;display:flex;flex-direction:column;height:100%;">
    {{ hw_title(slide) }}
    <div class="fade-up" style="margin-top:24px;flex:1;display:flex;flex-direction:column;">
        <div style="display:flex;background:var(--hw-title);border-radius:8px 8px 0 0;">
            <div style="flex:0 0 260px;padding:18px 24px;font-size:17px;color:#fff;font-weight:bold;">评估维度</div>
            {% for opt in slide.options %}
            <div style="flex:1;padding:18px 24px;font-size:17px;color:#fff;font-weight:bold;text-align:center;">{{ opt }}</div>
            {% endfor %}
        </div>
        {% for cr_idx in range(slide.criteria | length) %}
        <div style="display:flex;{% if not loop.first %}border-top:1px solid var(--hw-line);{% endif %}background:{% if loop.index is even %}var(--hw-bg-gray){% else %}#fff{% endif %};align-items:center;">
            <div style="flex:0 0 260px;padding:16px 24px;font-size:18px;color:var(--hw-title);font-weight:bold;">{{ slide.criteria[cr_idx] }}</div>
            {% for col_idx in range(slide.options | length) %}
            {% set score = slide.scores[cr_idx][col_idx] %}
            <div style="flex:1;padding:16px;display:flex;justify-content:center;">
                {# Harvey ball via conic-gradient #}
                <div style="width:40px;height:40px;border-radius:50%;background:conic-gradient(var(--hw-red) {{ score * 90 }}deg, var(--hw-light-gray) 0);display:flex;align-items:center;justify-content:center;">
                    <div style="width:30px;height:30px;border-radius:50%;background:inherit;display:flex;align-items:center;justify-content:center;">
                        <div style="width:20px;height:20px;border-radius:50%;background:{% if score >= 3 %}var(--hw-red){% elif score == 2 %}var(--hw-orange){% else %}var(--hw-light-gray){% endif %};"></div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endfor %}
    </div>
    {% if slide.legend_text %}
    <div class="fade-up" style="display:flex;gap:28px;margin-top:16px;font-size:15px;color:var(--hw-muted);">
        {% for lg in slide.legend_text %}<span>{{ lg }}</span>{% endfor %}
    </div>
    {% endif %}
    {% if slide.summary %}
    <div class="fade-up" style="margin-top:auto;padding:18px 28px;background:var(--hw-bg-gray);border-left:5px solid var(--hw-red);font-size:20px;color:var(--hw-title);">{{ slide.summary }}</div>
    {% endif %}
</div>
