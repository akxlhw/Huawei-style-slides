<div class="slide-content" style="padding-top:90px;padding-right:90px;padding-bottom:80px;display:flex;flex-direction:column;background:linear-gradient(180deg, #FFFFFF 0%, var(--hw-bg-gray) 100%);">
    {% from 'huawei-macros.j2' import hw_title %}
    {{ hw_title(slide) }}<div class="fade-up" style="display:flex;align-items:stretch;gap:0;margin-top:56px;flex:1;">
        {% for st in slide.stages %}
        <div style="flex:1;display:flex;align-items:stretch;">
            <div style="flex:1;background:var(--hw-white);border:1px solid var(--hw-light-gray);border-top:6px solid var(--hw-{{ st.color }});border-radius:6px;padding:36px 24px;display:flex;flex-direction:column;align-items:center;text-align:center;">
                <div style="width:64px;height:64px;border-radius:50%;background:var(--hw-{{ st.color }});color:var(--hw-white);display:flex;align-items:center;justify-content:center;font-size:30px;font-weight:bold;margin-bottom:24px;">{{ loop.index }}</div>
                <div style="font-size:30px;font-weight:bold;color:var(--hw-{{ st.color }});margin-bottom:16px;">{{ st.title }}</div>
                <div style="font-size:19px;color:var(--hw-body);line-height:1.6;">{{ st.description }}</div>
            </div>
            {% if not loop.last %}
            <div style="display:flex;align-items:center;padding:0 8px;font-size:40px;color:var(--hw-med-gray);">→</div>
            {% endif %}
        </div>
        {% endfor %}
    </div>
    {% if slide.source %}<div class="slide-source fade-up">来源：{{ slide.source }}</div>{% endif %}
</div>
