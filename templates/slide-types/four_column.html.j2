<div class="slide-content" style="padding-top:90px;padding-right:90px;padding-bottom:80px;display:flex;flex-direction:column;background:linear-gradient(180deg, #FFFFFF 0%, var(--hw-bg-gray) 100%);">
    {% from 'huawei-macros.j2' import hw_title %}
    {{ hw_title(slide) }}<div class="fade-up" style="display:flex;gap:24px;margin-top:40px;flex:1;">
        {% for col in slide.columns %}
        <div style="flex:1;background:var(--hw-white);border:1px solid var(--hw-light-gray);border-radius:6px;padding:32px 24px;display:flex;flex-direction:column;align-items:center;text-align:center;">
            <div style="width:56px;height:56px;border-radius:50%;background:var(--hw-red);color:var(--hw-white);display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:bold;margin-bottom:20px;">{{ col.num }}</div>
            <div style="font-size:26px;font-weight:bold;color:var(--hw-red);margin-bottom:16px;">{{ col.title }}</div>
            <div style="width:60%;height:2px;background:var(--hw-light-gray);margin-bottom:20px;"></div>
            <div style="display:flex;flex-direction:column;gap:12px;">
                {% for p in col.points %}
                <div style="font-size:19px;color:var(--hw-body);">{{ p }}</div>
                {% endfor %}
            </div>
        </div>
        {% endfor %}
    </div>
    {% if slide.source %}<div class="slide-source fade-up">来源：{{ slide.source }}</div>{% endif %}
</div>
