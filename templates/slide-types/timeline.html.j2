<div class="slide-content" style="padding-top:90px;padding-right:90px;padding-bottom:80px;display:flex;flex-direction:column;background:linear-gradient(180deg, #FFFFFF 0%, var(--hw-bg-gray) 100%);">
    {% from 'huawei-macros.j2' import hw_title %}
    {{ hw_title(slide) }}

    <div style="flex:1;display:flex;align-items:center;position:relative;padding-top:20px;">
        <!-- Connecting line -->
        <div style="position:absolute;top:50%;left:100px;right:100px;height:6px;background:linear-gradient(90deg, var(--hw-red) 0%, var(--hw-orange) 100%);border-radius:3px;transform:translateY(-50%);z-index:0;"></div>

        <div style="display:flex;justify-content:space-between;width:100%;padding:0 60px;z-index:1;">
            {% for milestone in slide.milestones %}
            <div class="fade-up" style="width:420px;text-align:center;">
                <div style="display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;border-radius:50%;background:var(--hw-white);border:6px solid var(--hw-red);box-shadow:0 6px 20px rgba(199,0,11,0.25);margin-bottom:28px;">
                    <span style="font-family:var(--font-en);font-size:20px;font-weight:800;color:var(--hw-red);">{{ loop.index }}</span>
                </div>
                <div style="font-family:var(--font-en);font-size:22px;font-weight:700;color:var(--hw-red);margin-bottom:10px;letter-spacing:0.08em;">{{ milestone.date }}</div>
                <div style="font-size:28px;font-weight:700;color:var(--hw-title);margin-bottom:12px;">{{ milestone.label }}</div>
                <div class="card" style="padding:24px;text-align:left;border-top:4px solid var(--hw-red);">
                    <p style="font-size:20px;color:var(--hw-body);line-height:1.5;margin:0;">{{ milestone.description }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    {% if slide.number is defined %}
    <div class="slide-number">{{ slide.number }}</div>
    {% endif %}
</div>
